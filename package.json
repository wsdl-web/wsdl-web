{
  "name": "wsdl-web",
  "version": "0.9.1",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "description": "A web-based WSDL explorer and SOAP client. Use as a standalone page, embed via script tag, or include as a React component.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/wsdl-web/wsdl-web"
  },
  "keywords": [
    "wsdl",
    "soap",
    "web-services",
    "explorer",
    "react",
    "embeddable"
  ],
  "main": "./dist-lib/wsdl-web.cjs",
  "module": "./dist-lib/wsdl-web.mjs",
  "types": "./dist-lib/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist-lib/wsdl-web.mjs",
      "require": "./dist-lib/wsdl-web.cjs",
      "types": "./dist-lib/types/index.d.ts"
    },
    "./style.css": "./dist-lib/wsdl-web.css"
  },
  "files": [
    "dist-lib",
    "dist-standalone"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "vite build --config vite.config.lib.ts && tsc --project tsconfig.lib.json",
    "build:standalone": "vite build --config vite.config.standalone.ts",
    "build:all": "npm run build && npm run build:lib && npm run build:standalone",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "prepublishOnly": "npm run build:lib"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "prismjs": "^1.30.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
